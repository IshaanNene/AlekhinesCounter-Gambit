{erl_opts, [debug_info]}.

{deps, [
    {grpcbox, "0.17.1"},
    %% syn: a distributed, eventually-consistent process registry. It carries the
    %% game-id -> pid mapping across the cluster so any node can address any live
    %% game, which is what lets the session tier run more than one replica.
    {syn, "3.3.0"},
    %% eredis: minimal Redis client for the durable session checkpoint that lets a
    %% game re-home to a surviving node after the node owning it dies.
    {eredis, "1.7.1"}
]}.

%% Protobuf/gRPC codegen from the shared contracts at the repo root.
{grpc, [
    {protos, ["../../proto/session/v1"]},
    {gpb_opts, [
        {i, "../../proto"},
        {module_name_suffix, "_pb"},
        {strings_as_binaries, true},
        {maps, true},
        {maps_unset_optional, omitted}
    ]}
]}.

{plugins, [grpcbox_plugin]}.

%% chatterbox (grpcbox's HTTP/2 layer) predates OTP 29 and builds with
%% warnings_as_errors; OTP 29 added a deprecation warning for bare `catch`,
%% which turns those warnings into build failures. Replace its erl_opts to drop
%% warnings_as_errors and silence the new deprecation.
{overrides, [
    {override, chatterbox, [
        {erl_opts, [debug_info, nowarn_deprecated_catch]}
    ]}
]}.

{shell, [{apps, [session_manager]}]}.

{relx, [
    {release, {session_manager, "0.1.0"}, [session_manager, sasl]},
    {mode, prod},
    {vm_args, "./config/vm.args"},
    {sys_config, "./config/sys.config"}
]}.

{eunit_opts, [verbose]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]}
    ]}
]}.

{dialyzer, [
    {warnings, [unknown]}
]}.
