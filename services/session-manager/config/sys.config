[
    {session_manager, [
        %% The gRPC listen port; ACG_SESSION_PORT overrides this at runtime.
        {start_grpc, true},
        {grpc_port, 50053}
    ]},
    {kernel, [
        {logger_level, info},
        {logger, [
            {handler, default, logger_std_h, #{
                formatter => {logger_formatter, #{
                    single_line => true,
                    template => [time, " ", level, " ", msg, "\n"]
                }}
            }}
        ]}
    ]}
].
